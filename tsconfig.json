{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "moduleSuffixes": [
      ".native",
      ".web",
      ""
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "postcss.config.mjs",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "app-example"
  ]
}
